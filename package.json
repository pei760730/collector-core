{
  "name": "@pei760730/collector-core",
  "version": "0.3.0",
  "description": "三個短影音收集 collector 的共用核心 —— 純 pipeline + utils",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts/voc/dedup_vectors.json": "./contracts/voc/dedup_vectors.json"
  },
  "files": [
    "dist",
    "contracts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
